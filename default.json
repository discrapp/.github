{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Denver",
  "schedule": ["after 10pm every weekday", "before 5am every weekday", "every weekend"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dependency Dashboard",
  "semanticCommits": "enabled",
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "commitMessageExtra": "to {{newValue}}",
  "commitMessageTopic": "{{depName}}",
  "platformAutomerge": true,
  "constraintsFiltering": "strict",
  "rebaseWhen": "conflicted",
  "labels": ["dependencies", "renovate"],
  "assignees": ["@benniemosher"],
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "assignees": ["@benniemosher"]
  },
  "packageRules": [
    {
      "description": "Group ESLint ecosystem - must upgrade together to avoid peer dep conflicts",
      "groupName": "eslint packages",
      "matchPackageNames": ["eslint", "/^@eslint//", "/^eslint-plugin-/", "/^@typescript-eslint//"]
    },
    {
      "description": "Block ESLint v10 - eslint-plugin-react (via eslint-config-next) does not support it yet",
      "matchPackageNames": ["eslint"],
      "allowedVersions": "<10"
    },
    {
      "description": "Automerge patch and minor updates when tests pass",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "GitHub Actions - group and automerge patch/minor",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "github-actions non-major",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Pre-commit hooks - group updates",
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    }
  ]
}
